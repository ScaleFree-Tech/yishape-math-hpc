<?xml version="1.0" encoding="UTF-8"?>
<project name="maven-antrun-" default="main">
  <target name="main">
    <resourcecount property="hpc.bundled.native.count">
      <fileset dir="E:\work\yishape-math-hpc\target\classes/META-INF/native-libs" erroronmissingdir="false">
        <include name="**/*.dll" />
        <include name="**/*.so" />
        <include name="**/*.dylib" />
      </fileset>
    </resourcecount>
    <echo message="[yishape-math-hpc] 已打入原生库文件数: ${hpc.bundled.native.count}" />
    <fail message="未在 JAR classes 下发现任何原生库。请在 E:\work\yishape-math-hpc/libs/&lt;classifier>/ 放置 *.dll/*.so/*.dylib，或使用 -DskipNativeBuild=false 在本机 cargo 构建当前平台。">
      <condition>
        <equals arg2="0" arg1="${hpc.bundled.native.count}" />
      </condition>
    </fail>
  </target>
</project>
